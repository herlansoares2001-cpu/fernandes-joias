// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(uuid()) @db.Uuid
  email     String    @unique @db.VarChar(255)
  password  String    @db.VarChar(255)
  role      String    @default("USER") @db.VarChar(50)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  orders    Order[]
  addresses Address[]
}

model Address {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @db.Uuid
  user         User     @relation(fields: [userId], references: [id])
  street       String   @db.VarChar(255)
  city         String   @db.VarChar(100)
  state        String   @db.VarChar(50)
  postalCode   String   @db.VarChar(20)
  country      String   @db.VarChar(100)
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  orders       Order[]
}

model Order {
  id                String      @id @default(uuid()) @db.Uuid
  userId            String      @db.Uuid
  user              User        @relation(fields: [userId], references: [id])
  shippingAddressId String      @db.Uuid
  shippingAddress   Address     @relation(fields: [shippingAddressId], references: [id])
  totalAmount       Decimal     @db.Decimal(12, 2)
  currency          String      @default("BRL") @db.VarChar(3)
  status            String      @default("PENDING") @db.VarChar(50) // PENDING, PAID, CANCELLED, SHIPPED
  idempotencyKey    String?     @unique @db.VarChar(255)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  items             OrderItem[]

  @@index([userId])
  @@index([status])
  @@index([userId, status])
}

model OrderItem {
  id            String   @id @default(uuid()) @db.Uuid
  orderId       String   @db.Uuid
  order         Order    @relation(fields: [orderId], references: [id])
  variantSku    String   @db.VarChar(100)
  variant       Variant  @relation(fields: [variantSku], references: [sku])
  quantity      Int
  unitPrice     Decimal  @db.Decimal(12, 2)
  engravingText String?  @db.VarChar(255)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Product {
  id               String    @id @default(uuid()) @db.Uuid
  slug             String    @unique @db.VarChar(255)
  name             String    @db.VarChar(255)
  description      String?   @db.Text
  basePrice        Decimal   @db.Decimal(12, 2)
  metalType        String?   @db.VarChar(50)
  gemstone         String?   @db.VarChar(100)
  certificationUrl String?   @db.VarChar(255)
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  variants         Variant[]

  @@index([isActive])
  @@index([isActive, createdAt])
}

model Variant {
  sku             String      @id @db.VarChar(100)
  productId       String      @db.Uuid
  product         Product     @relation(fields: [productId], references: [id])
  size            String?     @db.VarChar(20)
  priceAdjustment Decimal     @default(0.00) @db.Decimal(12, 2)
  weightGrams     Decimal?    @db.Decimal(8, 2)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  inventory       Inventory?
  orderItems      OrderItem[]
}

model Inventory {
  sku               String   @id @db.VarChar(100)
  variant           Variant  @relation(fields: [sku], references: [sku])
  quantityAvailable Int      @default(0)
  quantityReserved  Int      @default(0)
  lastUpdated       DateTime @default(now()) @updatedAt
}
